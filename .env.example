# Copy this file to .env and adjust values per environment.
# Never commit the real .env file.

NODE_ENV=development
PORT=3000

# TODO: replace with the real company name shown on the main menu, e.g.
# "<Company> Merchant Services :-)"
APP_NAME=Acme

# TODO: replace with the real short code used to prefix Service Reference
# numbers, e.g. "<CODE>-MS-1102"
COMPANY_CODE=ACME

# session store: "memory" (dev/demo only) or "redis" (required for staging/prod)
SESSION_STORE=memory
REDIS_URL=redis://127.0.0.1:6379

# Should match/slightly exceed the USSD gateway's session timeout window (typically 60-180s).
SESSION_TTL_SECONDS=180

LOG_LEVEL=info
LOG_DIR=logs

# TODO: replace with the real support team inbox — every ticket (query,
# complaint, speedpoint request) is emailed here.
SUPPORT_EMAIL=support@example.com

# Preferred production path: SendGrid's HTTP API (works through firewalls
# that block raw SMTP). Get a free API key at https://signup.sendgrid.com,
# verify a Single Sender, then fill both of these in.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Fallback only, if the client mandates their own mail relay instead of
# SendGrid. Leave blank otherwise — emailService automatically falls back to
# a free Ethereal test inbox for local dev/demo and logs a preview URL.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=USSD App <no-reply@example.com>

# ── Mahindra Comviva VAS Cloud-Service-Creation HTTP(S) Pull Protocol ────────
# TODO: every value below is a PLACEHOLDER from Comviva's generic protocol
# doc, not confirmed for our node. Do not point this at the real gateway
# until the Comviva/Mahindra integration team confirms all of these
# (see PROGRESS.md "API Comviva").

# Tag (query-string key) names the gateway will use when calling us.
COMVIVA_MSISDN_TAG=MSISDN
COMVIVA_SESSION_ID_TAG=sessionId
COMVIVA_INPUT_TAG=input
COMVIVA_NEW_REQUEST_TAG=newRequest
COMVIVA_USERID_TAG=userid
COMVIVA_PASSWORD_TAG=password
COMVIVA_CLEAN_TAG=clean
COMVIVA_STATUS_TAG=status
COMVIVA_CLEAN_MESSAGE=clean-session

# Node identifiers (doc params 12-13). Not yet confirmed whether our app
# needs to read/act on these or they're purely Comviva-internal — currently
# only logged for traceability if present, nothing depends on their value.
COMVIVA_UNIQUE_ID_TAG=uniqueId
COMVIVA_MULTI_ACCESS_CODE_TAG=multiAccessCode

# Credentials the gateway must present on every request. Blank = no request
# will authenticate — fill in once Comviva provisions our node.
COMVIVA_USER_ID=
COMVIVA_PASSWORD=

# Response header names we send back to the gateway.
COMVIVA_FREEFLOW_HEADER=Freeflow
COMVIVA_CHARGE_HEADER=charge
COMVIVA_AMOUNT_HEADER=amount
COMVIVA_CPREFID_HEADER=cpRefId
COMVIVA_MENUCODE_HEADER=menucode

# This is a free merchant-support line — leave charging disabled unless the
# client explicitly confirms otherwise for this service.
COMVIVA_CHARGE_ENABLED=false
COMVIVA_CHARGE_AMOUNT=0
